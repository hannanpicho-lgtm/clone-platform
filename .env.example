# Copy to .env.local for local development, .env.test.local for tests,
# or .env.production.local for production automation.
# Canonical Supabase variables are standardized below.

# Frontend variables read by Vite as `import.meta.env.VITE_*`
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional local/test tenant override used by Node smoke tests
TEST_TENANT_ID=tank

# Optional local Supabase CLI project ref
SUPABASE_PROJECT_REF=

# Canonical backend and Node-script variables
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Backward-compatible aliases still recognized by scripts, but avoid adding new usage.
# SUPABASE_SERVICE_KEY=
# VITE_SUPABASE_KEY=

# Admin-only tokens for privileged test scripts
SUPABASE_ADMIN_API_KEY=
ADMIN_API_KEY=
SUPABASE_JWT_SECRET=

# Comma-separated allowlist of production frontend origins
CORS_ALLOWED_ORIGINS=

# Emergency-only admin bypass via static key (keep false in production)
ALLOW_SUPER_ADMIN_KEY_BYPASS=false
