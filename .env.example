# Copy to .env and fill values
# These are read by Vite as `import.meta.env.VITE_*`
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_ANON_KEY=

# For local Supabase (`supabase start`) use the full URL (example: http://localhost:54321)
VITE_SUPABASE_URL=

# Optionally, if you use Supabase CLI locally, set the project ref too
SUPABASE_PROJECT_REF=

# Backend function environment variables
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ADMIN_API_KEY=
SUPABASE_JWT_SECRET=

# Comma-separated allowlist of production frontend origins
CORS_ALLOWED_ORIGINS=

# Emergency-only admin bypass via static key (keep false in production)
ALLOW_SUPER_ADMIN_KEY_BYPASS=false
