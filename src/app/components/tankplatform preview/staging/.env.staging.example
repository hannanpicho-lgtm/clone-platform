# TankPlatform staging environment variables
# Copy to .env.staging and replace values.

NODE_ENV=staging
APP_ENV=staging
APP_NAME=TankPlatform
APP_HOST=0.0.0.0
APP_PORT=4001
APP_URL=https://staging.tankplatform-workbench.com

# Keep isolated from production
DATABASE_URL=postgresql://tankplatform_staging:<REPLACE_PASSWORD>@127.0.0.1:5432/tankplatform_staging

# If your app uses discrete DB variables instead of DATABASE_URL, uncomment these:
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=tankplatform_staging
# DB_USER=tankplatform_staging
# DB_PASSWORD=<REPLACE_PASSWORD>

# Use separate storage path or bucket for staging
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/var/www/tankplatform/staging/storage
# STORAGE_DRIVER=s3
# STORAGE_S3_BUCKET=tankplatform-staging
# STORAGE_S3_REGION=<REPLACE_REGION>
# STORAGE_S3_ACCESS_KEY_ID=<REPLACE_ACCESS_KEY>
# STORAGE_S3_SECRET_ACCESS_KEY=<REPLACE_SECRET>

# Optional isolation for cache/queues
REDIS_URL=redis://127.0.0.1:6379/2
CACHE_PREFIX=tankplatform_staging
QUEUE_PREFIX=tankplatform_staging

# Ensure staging cannot send real emails/sms unless explicitly desired
MAIL_MODE=disabled
SMS_MODE=disabled
