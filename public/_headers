# All HTML routes served by the SPA: never cache so users always get the latest build.
/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Vite outputs content-hashed filenames under /assets/ — safe to cache for 1 year.
# A new deploy produces new filenames, so old caches are never stale.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
